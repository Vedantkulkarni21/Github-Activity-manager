# --- Database (Supabase Postgres connection string, asyncpg driver) ---
# Get this from Supabase: Project Settings -> Database -> Connection string -> URI
# Make sure to change "postgresql://" to "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# --- GitHub OAuth App (Settings -> Developer settings -> OAuth Apps) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must exactly match the "Authorization callback URL" set on the OAuth App
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback

# --- GitHub Webhook ---
# Random string you choose; used to verify incoming webhook signatures (HMAC-SHA256)
GITHUB_WEBHOOK_SECRET=

# --- Slack Incoming Webhook (Slack App -> Incoming Webhooks) ---
SLACK_WEBHOOK_URL=
# Optional, only needed if you later add Slack slash commands / event subscriptions
SLACK_SIGNING_SECRET=

# --- App secrets (generate your own, do not reuse example values) ---
# 32 url-safe base64 bytes, e.g. python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Any long random string, e.g. python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# --- URLs ---
# Publicly reachable URL of THIS backend (used to build the webhook callback URL)
BACKEND_PUBLIC_URL=http://localhost:8000
# URL of the deployed React frontend (used for CORS + post-login redirect)
FRONTEND_URL=http://localhost:5173

ENVIRONMENT=development
